{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/agentic-enterprise-origin-ledger/schemas/human-contribution-attribution.schema.json",
  "title": "Human Contribution Attribution",
  "description": "A record that attributes human contributions across enterprise knowledge origin, agent-skill transformation, cross-department execution, human judgment, and verified outcomes without yet assigning monetary value.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "attribution_id",
    "created_at",
    "attribution_scope",
    "lineage",
    "methodology",
    "human_contributors",
    "non_human_support",
    "aggregate_attribution",
    "governance",
    "integrity",
    "lifecycle"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.4.0"
    },
    "record_type": {
      "type": "string",
      "const": "human_contribution_attribution"
    },
    "attribution_id": {
      "type": "string",
      "pattern": "^hca_[a-z0-9][a-z0-9._-]{7,127}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "attribution_scope": {
      "$ref": "#/$defs/attributionScope"
    },
    "lineage": {
      "$ref": "#/$defs/lineage"
    },
    "methodology": {
      "$ref": "#/$defs/methodology"
    },
    "human_contributors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/humanContributor"
      }
    },
    "non_human_support": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonHumanSupport"
      }
    },
    "aggregate_attribution": {
      "$ref": "#/$defs/aggregateAttribution"
    },
    "governance": {
      "$ref": "#/$defs/governance"
    },
    "integrity": {
      "$ref": "#/$defs/integrity"
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycle"
    },
    "annotations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/annotation"
      },
      "default": []
    }
  },
  "$defs": {
    "actorReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_id",
        "actor_type"
      ],
      "properties": {
        "actor_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "human",
            "human_team",
            "agent",
            "system",
            "organization"
          ]
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "digest"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512",
            "blake3"
          ]
        },
        "digest": {
          "type": "string",
          "minLength": 16,
          "maxLength": 512
        },
        "signed_by": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        }
      }
    },
    "attributionScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization_id",
        "purpose",
        "period",
        "outcome_scope",
        "monetary_allocation_in_scope"
      ],
      "properties": {
        "organization_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "period": {
          "$ref": "#/$defs/timePeriod"
        },
        "outcome_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        },
        "monetary_allocation_in_scope": {
          "type": "boolean",
          "const": false
        },
        "decision_context": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        }
      }
    },
    "timePeriod": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_at",
        "end_at"
      ],
      "properties": {
        "start_at": {
          "type": "string",
          "format": "date-time"
        },
        "end_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_record_id",
        "origin_id",
        "skill_binding_id",
        "execution_trace_ids",
        "trace_integrities",
        "outcome_references"
      ],
      "properties": {
        "origin_record_id": {
          "type": "string",
          "pattern": "^ekor_[a-z0-9][a-z0-9._-]{7,127}$"
        },
        "origin_id": {
          "type": "string",
          "pattern": "^origin_[a-z0-9][a-z0-9._-]{5,127}$"
        },
        "skill_binding_id": {
          "type": "string",
          "pattern": "^kasb_[a-z0-9][a-z0-9._-]{7,127}$"
        },
        "execution_trace_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^cdet_[a-z0-9][a-z0-9._-]{7,127}$"
          }
        },
        "trace_integrities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/traceIntegrity"
          }
        },
        "outcome_references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "traceIntegrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "integrity"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "pattern": "^cdet_[a-z0-9][a-z0-9._-]{7,127}$"
        },
        "integrity": {
          "$ref": "#/$defs/integrity"
        }
      }
    },
    "methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method_id",
        "method_version",
        "method_type",
        "normalization_basis",
        "counterfactual_required",
        "evidence_threshold",
        "dimensions",
        "rounding_precision",
        "limitations"
      ],
      "properties": {
        "method_id": {
          "type": "string",
          "pattern": "^method_[a-z0-9][a-z0-9._-]{5,127}$"
        },
        "method_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "method_type": {
          "type": "string",
          "enum": [
            "evidence_weighted_causal_attribution",
            "panel_reviewed_attribution",
            "hybrid",
            "other"
          ]
        },
        "normalization_basis": {
          "type": "string",
          "enum": [
            "per_trace",
            "per_outcome",
            "per_period",
            "custom"
          ]
        },
        "counterfactual_required": {
          "type": "boolean",
          "const": true
        },
        "evidence_threshold": {
          "type": "string",
          "enum": [
            "documented",
            "corroborated",
            "verified"
          ]
        },
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/attributionDimension"
          }
        },
        "rounding_precision": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "attributionDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension_id",
        "weight",
        "description"
      ],
      "properties": {
        "dimension_id": {
          "type": "string",
          "enum": [
            "origin_novelty",
            "domain_expertise",
            "contextual_judgment",
            "corrective_action",
            "authorization_responsibility",
            "outcome_validation",
            "stewardship",
            "coordination",
            "other"
          ]
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "humanContributor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contribution_id",
        "actor",
        "identity_visibility",
        "consent_status",
        "department_ids",
        "roles",
        "contribution_events",
        "causal_assessment",
        "dimension_scores",
        "computed_attribution",
        "responsibility",
        "dispute"
      ],
      "properties": {
        "contribution_id": {
          "type": "string",
          "pattern": "^contribution_[a-z0-9][a-z0-9._-]{5,127}$"
        },
        "actor": {
          "allOf": [
            {
              "$ref": "#/$defs/actorReference"
            },
            {
              "properties": {
                "actor_type": {
                  "enum": [
                    "human",
                    "human_team"
                  ]
                }
              }
            }
          ]
        },
        "identity_visibility": {
          "type": "string",
          "enum": [
            "named",
            "pseudonymous",
            "organization_only",
            "withheld"
          ]
        },
        "consent_status": {
          "type": "string",
          "enum": [
            "confirmed",
            "not_required",
            "pending",
            "restricted",
            "withdrawn"
          ]
        },
        "department_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "contribution_events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/contributionEvent"
          }
        },
        "causal_assessment": {
          "$ref": "#/$defs/causalAssessment"
        },
        "dimension_scores": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dimensionScore"
          }
        },
        "computed_attribution": {
          "$ref": "#/$defs/computedAttribution"
        },
        "responsibility": {
          "$ref": "#/$defs/responsibility"
        },
        "dispute": {
          "$ref": "#/$defs/dispute"
        }
      }
    },
    "contributionEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "source_record_type",
        "source_record_id",
        "source_element_id",
        "description",
        "effect_on_process",
        "evidence_references"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "pattern": "^cevent_[a-z0-9][a-z0-9._-]{5,127}$"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "origin_creation",
            "evidence_provision",
            "knowledge_capture",
            "skill_transformation",
            "domain_review",
            "operational_judgment",
            "correction",
            "approval",
            "rejection",
            "escalation",
            "coordination",
            "outcome_verification",
            "stewardship",
            "other"
          ]
        },
        "source_record_type": {
          "type": "string",
          "enum": [
            "enterprise_knowledge_origin_record",
            "knowledge_to_agent_skill_binding",
            "cross_department_execution_trace",
            "external_evidence"
          ]
        },
        "source_record_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "source_element_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "occurred_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "effect_on_process": {
          "type": "string",
          "enum": [
            "initiated",
            "enabled",
            "constrained",
            "corrected",
            "authorized",
            "validated",
            "redirected",
            "completed"
          ]
        },
        "evidence_references": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "causalAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "causal_role",
        "counterfactual",
        "causal_confidence",
        "dependency_links"
      ],
      "properties": {
        "causal_role": {
          "type": "string",
          "enum": [
            "necessary",
            "enabling",
            "corrective",
            "authorizing",
            "validating",
            "contextual",
            "mixed"
          ]
        },
        "counterfactual": {
          "$ref": "#/$defs/counterfactual"
        },
        "causal_confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "verified"
          ]
        },
        "dependency_links": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^contribution_[a-z0-9][a-z0-9._-]{5,127}$"
          }
        }
      }
    },
    "counterfactual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "without_contribution_outcome",
        "rationale",
        "confidence"
      ],
      "properties": {
        "without_contribution_outcome": {
          "type": "string",
          "enum": [
            "blocked",
            "degraded",
            "delayed",
            "higher_risk",
            "unchanged",
            "unknown"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "verified"
          ]
        }
      }
    },
    "dimensionScore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension_id",
        "raw_score",
        "evidence_quality",
        "rationale"
      ],
      "properties": {
        "dimension_id": {
          "type": "string",
          "enum": [
            "origin_novelty",
            "domain_expertise",
            "contextual_judgment",
            "corrective_action",
            "authorization_responsibility",
            "outcome_validation",
            "stewardship",
            "coordination",
            "other"
          ]
        },
        "raw_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "evidence_quality": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "verified"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1500
        }
      }
    },
    "computedAttribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weighted_score",
        "relative_weight",
        "weight_status",
        "calculation_reference",
        "monetary_value_assigned"
      ],
      "properties": {
        "weighted_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "relative_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "weight_status": {
          "type": "string",
          "enum": [
            "provisional",
            "confirmed",
            "disputed",
            "excluded"
          ]
        },
        "calculation_reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "monetary_value_assigned": {
          "type": "boolean",
          "const": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "weight_status": {
                "const": "excluded"
              }
            }
          },
          "then": {
            "properties": {
              "relative_weight": {
                "const": 0
              }
            }
          }
        }
      ]
    },
    "responsibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_authority",
        "risk_responsibility",
        "accountability_notes"
      ],
      "properties": {
        "decision_authority": {
          "type": "string",
          "enum": [
            "none",
            "advisory",
            "reviewer",
            "approver",
            "executor",
            "steward"
          ]
        },
        "risk_responsibility": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "final_authority"
          ]
        },
        "accountability_notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "dispute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "none",
            "open",
            "resolved",
            "rejected"
          ]
        },
        "raised_by": {
          "oneOf": [
            {
              "$ref": "#/$defs/actorReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        },
        "resolution": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        }
      }
    },
    "nonHumanSupport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support_id",
        "actor",
        "support_role",
        "related_element_ids",
        "influence_level",
        "excluded_from_human_attribution",
        "notes"
      ],
      "properties": {
        "support_id": {
          "type": "string",
          "pattern": "^support_[a-z0-9][a-z0-9._-]{5,127}$"
        },
        "actor": {
          "allOf": [
            {
              "$ref": "#/$defs/actorReference"
            },
            {
              "properties": {
                "actor_type": {
                  "enum": [
                    "agent",
                    "system",
                    "organization"
                  ]
                }
              }
            }
          ]
        },
        "support_role": {
          "type": "string",
          "enum": [
            "data_collection",
            "analysis",
            "recommendation",
            "policy_enforcement",
            "routing",
            "recordkeeping",
            "infrastructure",
            "other"
          ]
        },
        "related_element_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "influence_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "excluded_from_human_attribution": {
          "type": "boolean",
          "const": true
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    },
    "aggregateAttribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basis",
        "total_relative_weight",
        "unattributed_weight",
        "human_contribution_complete",
        "calculation_status",
        "allocation_readiness",
        "checks"
      ],
      "properties": {
        "basis": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "total_relative_weight": {
          "type": "number",
          "minimum": 0.999999,
          "maximum": 1.000001
        },
        "unattributed_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "human_contribution_complete": {
          "type": "boolean"
        },
        "calculation_status": {
          "type": "string",
          "enum": [
            "draft",
            "ready_for_review",
            "reviewed",
            "blocked"
          ]
        },
        "allocation_readiness": {
          "type": "string",
          "enum": [
            "not_ready",
            "provisional",
            "ready",
            "disputed"
          ]
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/attributionCheck"
          }
        }
      }
    },
    "attributionCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_type",
        "result",
        "notes"
      ],
      "properties": {
        "check_type": {
          "type": "string",
          "enum": [
            "dimension_weights",
            "relative_weights",
            "evidence_coverage",
            "causal_consistency",
            "duplicate_claims",
            "permission_compliance",
            "open_disputes",
            "identity_protection"
          ]
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "warning",
            "fail"
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1500
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_required",
        "review_status",
        "reviewers",
        "methodology_transparency",
        "identity_protection",
        "appeal_available",
        "prohibited_uses"
      ],
      "properties": {
        "review_required": {
          "type": "boolean",
          "const": true
        },
        "review_status": {
          "type": "string",
          "enum": [
            "not_reviewed",
            "in_review",
            "accepted",
            "rejected",
            "revision_required"
          ]
        },
        "reviewers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/actorReference"
          }
        },
        "methodology_transparency": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "identity_protection": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "appeal_available": {
          "type": "boolean"
        },
        "prohibited_uses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "review_notes": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "retention_policy"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "pending_review",
            "approved",
            "suspended",
            "invalidated",
            "archived"
          ]
        },
        "retention_policy": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "superseded_by": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^hca_[a-z0-9][a-z0-9._-]{7,127}$"
        },
        "invalidated_reason": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        }
      }
    },
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annotation_id",
        "created_at",
        "created_by",
        "text"
      ],
      "properties": {
        "annotation_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "$ref": "#/$defs/actorReference"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    }
  }
}
