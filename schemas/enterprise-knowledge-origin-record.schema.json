{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/agentic-enterprise-origin-ledger/schemas/enterprise-knowledge-origin-record.schema.json",
  "title": "Enterprise Knowledge Origin Record",
  "description": "A record for preserving the origin, contributors, evidence, capture context, permissions, and governance status of enterprise knowledge before it is used by AI agents.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "record_id",
    "created_at",
    "enterprise_context",
    "knowledge_origin",
    "capture_context",
    "knowledge_summary",
    "provenance",
    "rights_and_permissions",
    "governance_flags",
    "lifecycle"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "record_type": {
      "type": "string",
      "const": "enterprise_knowledge_origin_record"
    },
    "record_id": {
      "type": "string",
      "pattern": "^ekor_[a-z0-9][a-z0-9._-]{7,127}$",
      "description": "Globally unique identifier for this Enterprise Knowledge Origin Record."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "enterprise_context": {
      "$ref": "#/$defs/enterpriseContext"
    },
    "knowledge_origin": {
      "$ref": "#/$defs/knowledgeOrigin"
    },
    "capture_context": {
      "$ref": "#/$defs/captureContext"
    },
    "knowledge_summary": {
      "$ref": "#/$defs/knowledgeSummary"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "rights_and_permissions": {
      "$ref": "#/$defs/rightsAndPermissions"
    },
    "governance_flags": {
      "$ref": "#/$defs/governanceFlags"
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycle"
    },
    "annotations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/annotation"
      },
      "default": []
    }
  },
  "$defs": {
    "enterpriseContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization_id",
        "organization_name",
        "business_unit",
        "jurisdiction",
        "confidentiality"
      ],
      "properties": {
        "organization_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "organization_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "business_unit": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "jurisdiction": {
          "type": "string",
          "minLength": 2,
          "maxLength": 128
        },
        "confidentiality": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        },
        "system_boundary": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 512
        }
      }
    },
    "knowledgeOrigin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_id",
        "title",
        "origin_type",
        "description",
        "contributors"
      ],
      "properties": {
        "origin_id": {
          "type": "string",
          "pattern": "^origin_[a-z0-9][a-z0-9._-]{5,127}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "origin_type": {
          "type": "string",
          "enum": [
            "human_expertise",
            "team_practice",
            "process_document",
            "system_record",
            "regulatory_requirement",
            "customer_feedback",
            "external_standard",
            "research_finding",
            "combined_origin",
            "other"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "first_observed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "contributors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contributor"
          },
          "default": []
        },
        "origin_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "contributor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contributor_id",
        "contributor_type",
        "role",
        "contribution_type",
        "attribution_mode",
        "consent_status"
      ],
      "properties": {
        "contributor_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "contributor_type": {
          "type": "string",
          "enum": [
            "human",
            "team",
            "system",
            "organization",
            "external_organization"
          ]
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        },
        "role": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "contribution_type": {
          "type": "string",
          "enum": [
            "originator",
            "practitioner",
            "observer",
            "document_author",
            "reviewer",
            "translator",
            "knowledge_steward",
            "evidence_provider",
            "other"
          ]
        },
        "contribution_description": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        },
        "attribution_mode": {
          "type": "string",
          "enum": [
            "named",
            "pseudonymous",
            "organization_only",
            "withheld"
          ]
        },
        "consent_status": {
          "type": "string",
          "enum": [
            "confirmed",
            "not_required",
            "pending",
            "restricted",
            "withdrawn"
          ]
        }
      }
    },
    "captureContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capture_id",
        "captured_at",
        "captured_by",
        "capture_methods",
        "purpose",
        "limitations"
      ],
      "properties": {
        "capture_id": {
          "type": "string",
          "pattern": "^capture_[a-z0-9][a-z0-9._-]{5,127}$"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "captured_by": {
          "$ref": "#/$defs/actorReference"
        },
        "capture_methods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "interview",
              "direct_observation",
              "workshop",
              "document_extraction",
              "system_export",
              "incident_review",
              "agent_assisted_capture",
              "manual_entry",
              "other"
            ]
          }
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "default": []
        },
        "capture_environment": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1000
        }
      }
    },
    "actorReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_id",
        "actor_type"
      ],
      "properties": {
        "actor_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "human",
            "team",
            "agent",
            "system",
            "organization"
          ]
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        }
      }
    },
    "knowledgeSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "abstract",
        "operational_scope",
        "decision_contexts",
        "known_limitations"
      ],
      "properties": {
        "abstract": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "operational_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          }
        },
        "decision_contexts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "default": []
        },
        "known_limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "default": []
        },
        "excluded_uses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "default": []
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "verified"
          ]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence",
        "prior_origin_ids",
        "integrity"
      ],
      "properties": {
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "prior_origin_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^origin_[a-z0-9][a-z0-9._-]{5,127}$"
          },
          "uniqueItems": true,
          "default": []
        },
        "integrity": {
          "$ref": "#/$defs/integrity"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "evidence_type",
        "reference",
        "verification_status"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^evidence_[a-z0-9][a-z0-9._-]{5,127}$"
        },
        "evidence_type": {
          "type": "string",
          "enum": [
            "interview_record",
            "observation_record",
            "document",
            "system_log",
            "incident_record",
            "measurement",
            "regulatory_text",
            "external_reference",
            "other"
          ]
        },
        "reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "collected_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "unverified",
            "partially_verified",
            "verified",
            "disputed",
            "expired"
          ]
        },
        "verification_notes": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "digest"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256",
            "sha512",
            "blake3",
            "none"
          ]
        },
        "digest": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 512
        },
        "signed_by": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 256
        }
      }
    },
    "rightsAndPermissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "steward",
        "usage_scope",
        "attribution_required",
        "human_review_required",
        "permitted_uses",
        "prohibited_uses"
      ],
      "properties": {
        "steward": {
          "$ref": "#/$defs/actorReference"
        },
        "usage_scope": {
          "type": "string",
          "enum": [
            "internal_only",
            "approved_partners",
            "public",
            "restricted"
          ]
        },
        "attribution_required": {
          "type": "boolean"
        },
        "human_review_required": {
          "type": "boolean"
        },
        "permitted_uses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          }
        },
        "prohibited_uses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          }
        },
        "retention_policy": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1000
        },
        "license_reference": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1000
        }
      }
    },
    "governanceFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contains_personal_data",
        "contains_sensitive_business_information",
        "safety_critical",
        "regulatory_impact",
        "automated_execution_allowed"
      ],
      "properties": {
        "contains_personal_data": {
          "type": "boolean"
        },
        "contains_sensitive_business_information": {
          "type": "boolean"
        },
        "safety_critical": {
          "type": "boolean"
        },
        "regulatory_impact": {
          "type": "boolean"
        },
        "automated_execution_allowed": {
          "type": "boolean"
        },
        "required_controls": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "default": []
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "review"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "pending_review",
            "approved",
            "suspended",
            "retired"
          ]
        },
        "effective_from": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "superseded_by": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^ekor_[a-z0-9][a-z0-9._-]{7,127}$"
        },
        "review": {
          "$ref": "#/$defs/review"
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_reviewed",
            "in_review",
            "accepted",
            "rejected",
            "revision_required"
          ]
        },
        "reviewer": {
          "oneOf": [
            {
              "$ref": "#/$defs/actorReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2000
        }
      }
    },
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annotation_id",
        "created_at",
        "created_by",
        "text"
      ],
      "properties": {
        "annotation_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_by": {
          "$ref": "#/$defs/actorReference"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    }
  }
}
